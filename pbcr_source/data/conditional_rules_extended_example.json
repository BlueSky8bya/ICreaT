      "final manager = ConditionalRuleManager();",
      "manager.initializeRules(rules);",
      "",
      "// 나이 입력 시 조건부 규칙 평가",
      "manager.evaluateRules('age_input_uid', '25');",
      "bool isAdultConsentRequired = manager.isConditionalRequired('adult_consent_uid');"
