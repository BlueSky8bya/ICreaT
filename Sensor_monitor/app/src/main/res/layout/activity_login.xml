<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary">

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/logo"
        android:layout_width="80dp"
        android:layout_height="80dp"
        android:layout_marginBottom="20dp"
        android:src="@mipmap/ic_launcher_round"
        android:contentDescription="앱 아이콘"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.RoundedIcon"
        app:layout_constraintBottom_toTopOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="HCI Lab Monitor"
        android:textColor="@color/text_primary"
        android:textSize="26sp"
        android:fontFamily="sans-serif-black"
        android:letterSpacing="-0.02"
        app:layout_constraintBottom_toTopOf="@id/tvSubtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="워치 데이터 수집 앱"
        android:textColor="@color/text_secondary"
        android:textSize="15sp"
        android:fontFamily="sans-serif"
        android:letterSpacing="0.01"
        app:layout_constraintBottom_toTopOf="@id/tvScanResult"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- [2026-07-09] QR 로그인 Phase 1: 스캔 결과(studyId/subjectId) 표시. 미스캔 시 안내 문구. -->
    <TextView
        android:id="@+id/tvScanResult"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="QR 스캔으로 대상자를 매칭해 주세요"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toTopOf="@id/qrScanBtn"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- [2026-07-09] QR 로그인 Phase 1: 대상자 QR 스캔 버튼 (pbcr과 동일 JSON 규격: stdy_no/subject_id) -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/qrScanBtn"
        android:layout_width="0dp"
        android:layout_height="60dp"
        android:layout_marginHorizontal="32dp"
        android:text="QR 스캔"
        android:textSize="17sp"
        android:textColor="#FFFFFF"
        app:cornerRadius="16dp"
        app:backgroundTint="@color/accent_primary"
        app:elevation="2dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- [2026-07-09] 시작 버튼 제거 — QR 스캔 성공 시 즉시 자동 로그인. 캐시 있으면 화면 진입 없이 자동 진입. -->

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="© 2026 Gachon HCI Lab"
        android:textColor="@color/text_tertiary"
        android:textSize="12sp"
        android:fontFamily="sans-serif"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>